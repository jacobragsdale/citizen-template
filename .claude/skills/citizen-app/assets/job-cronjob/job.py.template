"""Scheduled job entry point.

Run once:  uv run --env-file .env python -m app.job
Dry run:   uv run python -m app.job --dry-run   (used by validation; must exit 0)

The build stage replaces the body of run() with the real work. Keep --dry-run
working: it must exercise setup/wiring without doing anything irreversible.
Data comes from the preconfigured sources in app.data (see AGENTS.md).
"""

import argparse

from app.data import get_source

# The build stage sets this to the source the citizen chose ("stocks"|"bonds").
SOURCE_KEY = "stocks"


def run(*, dry_run: bool = False) -> None:
    source = get_source(SOURCE_KEY)
    rows = source.fetch()
    if dry_run:
        print(f"dry-run OK — '{source.key}' returned {len(rows)} rows")
        return
    # The build stage replaces this with the job's real work over `rows`.
    print(f"{source.label}: {len(rows)} records")
    for row in rows[:5]:
        print(row)


def main() -> None:
    parser = argparse.ArgumentParser(description="Run the scheduled job.")
    parser.add_argument("--dry-run", action="store_true",
                        help="exercise wiring without doing real work")
    args = parser.parse_args()
    run(dry_run=args.dry_run)


if __name__ == "__main__":
    main()
